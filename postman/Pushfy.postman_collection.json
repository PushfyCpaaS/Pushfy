    {
      "name": "Push (Public)",
      "description": "Browser/device SDK calls on `/v2/api.php`. Auth: public `app_id` only (safe for front-end). No signature is applied to these requests.",
      "auth": {
        "type": "noauth"
      },
      "item": [
        {
          "name": "Get Config",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{v2_url}}?r=/v1/push/config&app_id={{app_id}}",
              "host": [
                "{{v2_url}}"
              ],
              "query": [
                {
                  "key": "r",
                  "value": "/v1/push/config"
                },
                {
                  "key": "app_id",
                  "value": "{{app_id}}"
                }
              ]
            },
            "description": "Public config for the browser SDK (VAPID public key + opt-in). Authenticates with the public `app_id`. No signature.",
            "auth": {
              "type": "noauth"
