{
  "info": {
    "name": "Pushfy API",
    "_postman_id": "b3f7c2a1-4d5e-4f60-9a10-pushfy000001",
    "description": "Pushfy API collection: Messaging (SMS/RCS/Voice, status, balance), Push Notifications (public SDK + server HMAC) and Conversational AI (PushAgent).\n\nAUTH\n- Messaging: Bearer `{{api_token}}` (inherited from the collection).\n- Push (Public): public `{{app_id}}` in body/query, no signature.\n- Push (Server) & Conversational AI: HMAC. The collection pre-request script signs these automatically (X-PUSH-* from `push_key`/`push_secret`, X-PA-* from `pa_key`/`pa_secret`).\n\nFill the values in the 'Pushfy - Production' environment. See README.md to import and use.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// ===========================================================================",
          "// Pushfy auto-signer (collection-level pre-request).",
          "// Signs V2 HMAC requests (routes served by /v2/api.php) automatically.",
          "//   - Push SERVER routes (/v1/push/*)  -> X-PUSH-* headers + push_key/push_secret",
          "//   - PushAgent routes  (/v1/*)         -> X-PA-*   headers + pa_key/pa_secret",
          "// Classic Messaging requests and PUBLIC Push SDK routes are left untouched.",
          "// ===========================================================================",
          "",
          "// Only V2 requests go through the /v2/api.php gateway. Everything else",
          "// (classic messaging: /webapi, /apircsnativo.php, /getstatus, ...) is skipped.",
          "const rawUrl = pm.request.url.toString();",
          "if (rawUrl.indexOf('/v2/api.php') === -1) {",
          "    return; // classic messaging request - nothing to sign here",
          "}",
          "",
          "// The signed 'path' is the value of the ?r= query param. It includes any",
          "// resource ids, e.g. /v1/conversations/123/messages or /v1/push/campaigns/987/send.",
          "const r = pm.request.url.query.get('r') || '';",
          "",
          "// Public Push SDK routes authenticate with the public app_id only.",
          "// They must NOT be signed.",
          "const publicPushRoutes = [",
          "    '/v1/push/config',",
          "    '/v1/push/subscribe',",
          "    '/v1/push/unsubscribe',",
          "    '/v1/push/track'",
          "];",
          "if (publicPushRoutes.indexOf(r) !== -1) {",
          "    return; // public route - app_id auth, no signature",
          "}",
          "",
          "// Pick the credential set + header prefix by route family.",
          "const isPush    = r.indexOf('/v1/push/') === 0;",
          "const keyVar    = isPush ? 'push_key'    : 'pa_key';",
          "const secretVar = isPush ? 'push_secret' : 'pa_secret';",
          "const prefix    = isPush ? 'X-PUSH'      : 'X-PA';",
          "",
          "// Resolve credentials (environment wins, fall back to collection variables).",
          "const key    = pm.environment.get(keyVar)    || pm.collectionVariables.get(keyVar);",
          "const secret = pm.environment.get(secretVar) || pm.collectionVariables.get(secretVar);",
          "",
          "// Only sign when both the key and secret are actually configured.",
          "if (!key || !secret) {",
          "    console.log('[Pushfy signer] missing ' + keyVar + '/' + secretVar + ' - skipping signature.');",
          "    return;",
          "}",
          "",
          "// Canonical string:  timestamp \\n METHOD \\n path \\n sha256hex(body)",
          "// (GET/empty body -> sha256hex(\"\") ). Server allows a +/-300s timestamp window.",
          "const ts       = Math.floor(Date.now() / 1000).toString();",
          "const method   = pm.request.method.toUpperCase();",
          "const body     = (pm.request.body && pm.request.body.raw) ? pm.request.body.raw : '';",
          "const bodyHash = CryptoJS.SHA256(body).toString(CryptoJS.enc.Hex);",
          "const base     = ts + '\\n' + method + '\\n' + r + '\\n' + bodyHash;",
          "const sig      = CryptoJS.HmacSHA256(base, secret).toString(CryptoJS.enc.Hex);",
          "",
          "// Upsert the signing headers for this single request.",
          "pm.request.headers.upsert({ key: prefix + '-Key',       value: key });",
          "pm.request.headers.upsert({ key: prefix + '-Timestamp', value: ts });",
          "pm.request.headers.upsert({ key: prefix + '-Signature', value: sig });",
          "console.log('[Pushfy signer] signed ' + method + ' ' + r + ' with ' + prefix + '-* headers.');"
        ]
      }
    }
  ],
