    {
      "name": "Push (Server, HMAC)",
      "description": "Server-to-server Push API on `/v1/push/*`. Auth: HMAC with `X-PUSH-Key` / `X-PUSH-Timestamp` / `X-PUSH-Signature`, computed automatically by the collection pre-request script from `push_key` / `push_secret`.",
      "auth": {
        "type": "noauth"
      },
      "item": [
        {
          "name": "List Devices",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{v2_url}}?r=/v1/push/devices&status=active&platform=web&limit=100",
              "host": [
                "{{v2_url}}"
              ],
              "query": [
                {
                  "key": "r",
                  "value": "/v1/push/devices"
                },
                {
                  "key": "status",
                  "value": "active"
                },
                {
                  "key": "platform",
                  "value": "web"
                },
                {
                  "key": "limit",
                  "value": "100"
                }
              ]
            },
            "description": "List devices. HMAC-signed (`X-PUSH-*`) automatically by the collection pre-request script. Filters: `status`, `platform`, `limit` (max 500).",
            "auth": {
