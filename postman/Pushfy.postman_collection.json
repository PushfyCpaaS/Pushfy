    }
  ],
  "item": [
    {
      "name": "Messaging",
      "description": "Classic SMS / RCS / Voice API on `https://portal.pushfy.com`. Auth: Bearer `{{api_token}}` (inherited from the collection).",
      "item": [
        {
          "name": "Send SMS",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/webapi",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "webapi"
              ]
            },
            "description": "Send one SMS (async/queued). Returns an array `[{id,phone,date,ext_id}]`.\n\nKeep the `ext_id` you send to look up delivery status later.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messages\": [\n    {\n      \"ext_id\": \"order-1042\",\n      \"destinations\": [\n        {\n          \"to\": \"5511999999999\"\n        }\n      ],\n      \"text\": \"Your order #1042 has shipped\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Persist the ext_id we sent so 'Get Status' can look it up later.",
                  "try {",
                  "    var sent = JSON.parse(pm.request.body.raw);",
                  "    var extId = sent && sent.messages && sent.messages[0] && sent.messages[0].ext_id;",
                  "    if (extId) {",
                  "        pm.collectionVariables.set('last_ext_id', extId);",
                  "        console.log('Saved last_ext_id =', extId);",
                  "    }",
                  "} catch (e) {",
                  "    console.log('Could not parse request body for ext_id:', e);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Send Bulk SMS",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/webapi",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "webapi"
              ]
            },
            "description": "Send many SMS in one request (up to 100,000 messages). Each message returns its own row.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messages\": [\n    {\n      \"ext_id\": \"b1\",\n      \"destinations\": [\n        {\n          \"to\": \"5511999990001\"\n        }\n      ],\n      \"text\": \"Hi Ana\"\n    },\n    {\n      \"ext_id\": \"b2\",\n      \"destinations\": [\n        {\n          \"to\": \"5511999990002\"\n        }\n      ],\n      \"text\": \"Hi Bruno\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 2xx', function () {",
                  "    pm.expect(pm.response.code).to.be.within(200, 299);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Send RCS",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/apircsnativo.php",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "apircsnativo.php"
              ]
            },
            "description": "Send an RCS rich card (title/image/text/link button) against your provisioned 'API RCS' campaign.\n\nReturns `400 rcs_campaign_not_found` if the account has no 'API RCS' campaign; use `POST /rcs` to auto-create one.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messages\": [\n    {\n      \"ext_id\": \"order-1042\",\n      \"destinations\": [\n        {\n          \"to\": \"5511999999999\"\n        }\n      ],\n      \"title\": \"Your order shipped\",\n      \"image\": \"https://cdn.example.com/box.png\",\n      \"text\": \"Order #1042 is on its way\",\n      \"url\": \"https://shop.example.com/orders/1042\",\n      \"cta\": \"Track order\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 2xx', function () {",
                  "    pm.expect(pm.response.code).to.be.within(200, 299);",
                  "});"
                ]
              }
            }
          ]
        },
        {
